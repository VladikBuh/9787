# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'HippoRoomHub' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
    # Fix fmt 11.0.2 consteval errors with Xcode 26 / Clang 17+.
        fmt_base_h = "#{Pod::Config.instance.installation_root}/Pods/fmt/include/fmt/base.h"
        if File.exist?(fmt_base_h)
          text = File.read(fmt_base_h)
          marker = '// FMT_USE_CONSTEVAL override for Xcode 26 / Clang 17+'
          if text.include?(marker)
            puts "ℹ️ fmt/base.h already patched"
          else
            needle = "#if FMT_USE_CONSTEVAL\n#  define FMT_CONSTEVAL consteval"
            raise "fmt/base.h structure unexpected; cannot patch FMT_USE_CONSTEVAL" unless text.include?(needle)
            replacement = "#{marker}\n#undef FMT_USE_CONSTEVAL\n#define FMT_USE_CONSTEVAL 0\n#{needle}"
            File.chmod(0644, fmt_base_h)
            File.write(fmt_base_h, text.sub(needle, replacement))
            puts "🔧 Patched fmt/base.h to force FMT_USE_CONSTEVAL=0"
          end
        else
          puts "ℹ️ fmt/base.h not found (skipping consteval patch)"
        end
  end
end
